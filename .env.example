# Variables d'environnement requises — copier ce fichier en .env et remplir les valeurs.
# Ne jamais committer .env dans Git (déjà présent dans .gitignore).

# ── API LLM ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Base de données PostgreSQL / pgvector ─────────────────────────────────────
# POSTGRES_PASSWORD : mot de passe de l'utilisateur 'rag'.
# Utilisé par docker-compose pour créer le user ET pour construire DATABASE_URL.
# Ne jamais utiliser la valeur par défaut 'changeme' en production.
POSTGRES_PASSWORD=changeme

# DATABASE_URL : chaîne de connexion psycopg2.
# En contexte Docker, utiliser 'postgres' comme hostname (réseau interne Docker).
# En local sans Docker, utiliser 'localhost'.
DATABASE_URL=postgresql://rag:changeme@postgres:5432/rag

# ── Grafana ───────────────────────────────────────────────────────────────────
# Mot de passe du compte admin Grafana (login : admin).
# Accès via http://localhost:3000 après docker-compose up.
GF_ADMIN_PASSWORD=changeme